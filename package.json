{
    "name": "ai-templater",
    "version": "0.1.0",
    "author": "Ivan Linnik",
    "private": true,
    "type": "module",
    "bin": {
        "ait": "./dist/cli.js"
    },
    "files": [
        "dist",
        "agents",
        "shared",
        "templates"
    ],
    "scripts": {
        "prepare": "tsc",
        "build": "tsc",
        "dev": "tsx src/cli.ts",
        "init:self-test": "tsx src/cli.ts init",
        "check": "biome check .",
        "check:fix": "biome check --write .",
        "format": "biome format --write ."
    },
    "devDependencies": {
        "@biomejs/biome": "^2.3.10",
        "@types/node": "^22.10.1",
        "tsx": "^4.20.3",
        "typescript": "^5.6.3"
    },
    "dependencies": {
        "picocolors": "^1.1.1"
    }
}
