{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "noImplicitOverride": true,
        "noUncheckedIndexedAccess": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "declaration": false,
        "sourceMap": false,
        "types": ["node"],
        "removeComments": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["dist", "node_modules"]
}
